#!/usr/bin/env bash

runifexists(){
	local command="$1"
	shift
	progName=$(echo "$command" | cut -d' ' -f 1)
	if ( type $progName >/dev/null 2>&1 )
	then
		$command "$@"
	else
		return 1
	fi
}

output="$(runifexists "exiftool" "$@" || runifexists "ffprobe" "$@" || runifexists "id3v2 --list" "$@" || runifexists "file" "$@")"
echo "$output" \
	| grep -Piv 'File (Access|Inode Change|Modification) Date/Time' \
	| grep -Piv '^Directory ' \
	| sort
