#!/usr/bin/env bash

# designed to refine gboard speech-to-text transcriptions
# and whisper transcriptions

# make sure this is declared before the function
expressions=()

addEnclosureExpressions(){
	openSymbol="$1"
	closeSymbol="$2"
	name="$3"

	# handle noted open/closes
	expressions+=("s/[,\.]? ?([Oo]pen) ?\b${name}\b[,\.]? ?/ ${openSymbol}/g")
	expressions+=("s/[,\.]? ?([Cc]lose|[Ee]nd) ?\b${name}\b[,]? ?/${closeSymbol} /g")
	# guess at others
	expressions+=("s/[,\.]? ?\b${name}\b[,]? ?/ ${openSymbol} /g")
	expressions+=("s/ (?:${openSymbol}) ?(.+?) ?(?:${openSymbol}) / ${openSymbol}\$1${closeSymbol} /g;")
}

addPuncExpression(){
	puncSymbol="$1"
	name="$2"

	expressions+=("s/[,\.]? ?\b${name}\b[,\.]? ?/${puncSymbol} /g")
}

if [[ "$#" -eq 0 ]]
then
	echo "please provide a filepath"
	exit 1
fi


for filePath in "$@"
do

	if [[ -z "$filePath" ]]
	then
		continue
	elif [[ ! -f "$filePath" ]]
	then
		echo "file does not exist"
		continue
	fi

	fileNameFull="$(basename "$filePath")"
	fileName="${fileNameFull%.*}"
	fileDir="$(dirname "$filePath")"
	outPath="$fileDir/${fileName}_fixed.txt"

	echo -n "$fileName "

	localFixPath="$HOME/bin_local/_fix-transcription"

	fileStringOld="$(cat "$filePath")"
	# old method kept for reference
	# fileStringNew="$(echo "$fileStringOld" | \
	# 	tr -d '\r' | \
	# 	perl -p \
	# 	-e 's/(?:parentheses|\() ?(.+?)(?: and| end| close)? ?(?:parentheses|(?<=[^:;])\(|(?<=[^:;])\))/($1)/g;' \
	# 	-e 's/(?:quote|quotation mark|") ?([^:].+?)(?: and| end| close)? ?(?:quote|quotation mark|")/"$1"/g;' \
	# 	-e 's/(?:bracket|\[) ?(.+?)(?: and| end| close)? ?(?:bracket|\])/\[$1\]/g;' \
	# 	-e 's/(?:asterisk|\*) ?(.+?) ?(?:asterisk|\*)/\*$1\*/g;' \
	# 	-e 's/(ampersand|and [hp]ers[ae]nd|and percent)/&/g;' \
	# 	-e 's/:-\)/:\)/g;' \
	# 	-e 's/:-\(/:\(/g;' \
	# 	-e 's/[nN]ew line ?/\n/g;' \
	# 	-e 's/([\.!\?]"? ?[a-z])/\U\1/g;' \
	# 	-e 's/(^[a-z])/\U\1/g;' \
	# 	-e 's/ \.(?=[^\.])/./g;' \
	# 	-e 's/^ (?=\S)//g;' \
	# 	-e 's/ +$//g;' \
	# 	| cat)"
	
	fileStringNew="$(echo "$fileStringOld" | tr -d '\r')"

	# if the file contains the words "new line", erase existing new lines and opt for explicity ones only
	if echo "$fileStringOld" | grep -Piq "\b[Nn]ew line\b"
	then
		expressions+=("s/ *\n */ /g")
	fi

	expressions+=("s/\b[Nn]ew line\b[,\.]? */\n\n/g")

	addEnclosureExpressions '\(' '\)' '[Pp]arenthes[ei]s'
	addEnclosureExpressions '\[' '\]' '[Bb]rackets?'
	addEnclosureExpressions '\{' '\}' '([Cc]urly )?[Bb]races?'
	addEnclosureExpressions '\*' '\*' '[Aa]sterisks?'
	addEnclosureExpressions '"'  '"'  '[Qq]uotes?(ation mark)?'

	addPuncExpression ';' '[Ss]emi\-?[Cc]olon'
	addPuncExpression ':' '[Cc]olon'
	addPuncExpression ',' '[Cc]omma'
	addPuncExpression '.' '[Pp]eriod'
	addPuncExpression '!' '[Ee]xclamation point'
	addPuncExpression '?' '[Qq]uestion mark'
	addPuncExpression ' -' '[Dd]ash'

	expressions+=('s/ slash / \/ /g')

	expressions+=('s/([,\.] )?dot dot dot dot/..../g')
	expressions+=('s/([,\.] )?dot dot dot/.../g')

	expressions+=('s/ [Ss]miley face[\.,]/ :) /g')
	expressions+=('s/ [Ss]ad face[\.,]/ :( /g')
	expressions+=('s/ [Ww]orried face[\.,]/ <:( /g')
	expressions+=('s/ [Aa]ngry face[\.,]/ >:( /g')

	expressions+=('s/[,\.]? ?[Aa]mpersand[,\.]? ?/ & /g')
	expressions+=('s/^ +//g')
	expressions+=('s/ +$//g')
	expressions+=('s/(?<=[\(\[\{]) //g')
	expressions+=('s/ (?=[\)\]\}])//g')
	expressions+=('s/ (?=\.$)//g')
	expressions+=('s/ (?=\. )//g')
	expressions+=('s/ (?=[\)\]\}])//g')

	# standardize them dates into yyyy-mm-dd Monday/holiday format
	# as markdown headers
	expressions+=('s/^(\d{4})[,\. ]+(January|February|March|April|May|June|July|August|September|October|November|December|\d{1,2})[,\. ]+(\d{1,2})(st|nd|rd|th)?[,\. ]{0,2}((?:\s?[^ \.,]+){1,3})[,\.]?/# $1-$2-$3 $5/g')
	expressions+=('s/(?<=\d\-)January(?=\-\d)/01/g')
	expressions+=('s/(?<=\d\-)February(?=\-\d)/02/g')
	expressions+=('s/(?<=\d\-)March(?=\-\d)/03/g')
	expressions+=('s/(?<=\d\-)April(?=\-\d)/04/g')
	expressions+=('s/(?<=\d\-)May(?=\-\d)/05/g')
	expressions+=('s/(?<=\d\-)June(?=\-\d)/06/g')
	expressions+=('s/(?<=\d\-)July(?=\-\d)/07/g')
	expressions+=('s/(?<=\d\-)August(?=\-\d)/08/g')
	expressions+=('s/(?<=\d\-)September(?=\-\d)/09/g')
	expressions+=('s/(?<=\d\-)October(?=\-\d)/10/g')
	expressions+=('s/(?<=\d\-)November(?=\-\d)/11/g')
	expressions+=('s/(?<=\d\-)December(?=\-\d)/12/g')

	expressions+=('s/\n*[Ss]ection separator[,\.]\n*/\n\n---\n\n/g')

	# allow for custom expressions outside the repo
	if [[ -f "$localFixPath" ]]
	then
		while read -r line
		do
			# echo "local expression: $line"
			expressions+=("$line")
		done < <(cat "$localFixPath")
	fi

	# would be more efficient to chain these into one big perl call, but this is simpler
	for expression in "${expressions[@]}"
	do
		# echo "$expression"
		fileStringNew="$(echo "$fileStringNew" | perl -pe "$expression" | perl -0777 -pe 's/\n{3,}/\n\n/g')"
	done

	# zero out expressions at the end
	# we *could* assemble these outside of the for loop, but we may have more file-specific variations we want in the future
	expressions=()

	if [[ "$fileStringOld" != "$fileStringNew" ]]
	then
		echo "$fileStringNew" > "$outPath"
		echo "done"
	else
		echo "no changes"
	fi

done
