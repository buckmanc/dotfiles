#!/usr/bin/env bash

runifexists(){
	local command="$1"
	shift
	local progName
	progName=$(echo "$command" | cut -d' ' -f 1)
	if ( type $progName >/dev/null 2>&1 )
	then
		$command "$@"
	else
		return 1
	fi
}

runifexists "ascii-image-converter --color" "$@" || runifexists "magick identify" "$@" || runifexists "identify" "$@"


